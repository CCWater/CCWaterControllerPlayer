<Window x:Class="CCWaterControllerPlayer.Overlay.ImageOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Overlay"
        Width="300" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Border Background="#CC0D1117" CornerRadius="8" BorderBrush="#40FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Height="24" 
                  Background="Transparent" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText" Text="Image" Foreground="#80FFFFFF" FontSize="10" 
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Button Grid.Column="1" Content="📌" Click="PinButton_Click"
                        Background="Transparent" Foreground="#80FFFFFF" BorderThickness="0"
                        FontSize="10" Padding="6,2" Cursor="Hand" ToolTip="Pin"/>
                <Button Grid.Column="2" Content="&#x2716;" Click="CloseButton_Click"
                        Background="Transparent" Foreground="#80FFFFFF" BorderThickness="0"
                        FontSize="10" Padding="6,2" Cursor="Hand"/>
            </Grid>

            <Grid Grid.Row="1" Margin="4" AllowDrop="True" 
                  Drop="OnImageDrop" DragOver="OnDragOver"
                  MouseLeftButtonDown="OnPlaceholderClick" Cursor="Hand">
                <StackPanel x:Name="PlaceholderText"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📂" FontSize="24" HorizontalAlignment="Center" Foreground="#60FFFFFF"/>
                    <TextBlock Text="Drop or click to select image" 
                               Foreground="#40FFFFFF" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Image x:Name="OverlayImage" Stretch="Uniform" 
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
        </Grid>
    </Border>
</Window>
