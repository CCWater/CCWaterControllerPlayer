<Window x:Class="CCWaterControllerPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CCWaterControllerPlayer.Views"
        xmlns:vm="clr-namespace:CCWaterControllerPlayer.ViewModels"
        xmlns:services="clr-namespace:CCWaterControllerPlayer.Services"
        Title="CCWater Controller Player" 
        Icon="Resources/app.ico"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDarkBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
            <views:MonitorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RecordsViewModel}">
            <views:RecordsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HelpViewModel}">
            <views:HelpView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OverlayViewModel}">
            <views:OverlayView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource BackgroundMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="16,20,16,20">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.AppTitle}" 
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.AppSubtitle}" 
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="8,0,8,16">
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.NavMonitor}" 
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateToMonitorCommand}"/>
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.NavRecords}" 
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateToRecordsCommand}" Margin="0,4,0,0"/>
                    <Button Content="🖥 Overlay" 
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateToOverlayCommand}" Margin="0,4,0,0"/>
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.NavSettings}" 
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateToSettingsCommand}" Margin="0,4,0,0"/>
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.NavHelp}" 
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateToHelpCommand}" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="2"/>

                <Border Grid.Row="3" Background="{StaticResource BackgroundDarkBrush}" 
                        CornerRadius="8" Margin="8,0,8,12" Padding="12,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsControllerConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Grid.Column="1" Text="{Binding ControllerName}" 
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.Rate, StringFormat='{}{0}: '}" 
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding SamplingRate, StringFormat='{}{0} Hz'}" 
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.Rec, StringFormat=' | {0}: '}" 
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            <TextBlock Text="{Binding RecordCount}" 
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                        </StackPanel>

                        <Button Style="{StaticResource PrimaryButtonStyle}" 
                                Command="{Binding ConnectControllerCommand}"
                                HorizontalAlignment="Stretch">
                            <Button.Content>
                                <TextBlock HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnConnect}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsControllerConnected}" Value="True">
                                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnDisconnect}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ContentControl Content="{Binding CurrentView}"/>

            <Border Grid.Row="1" Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,8">
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
            </Border>
        </Grid>
    </Grid>
</Window>
