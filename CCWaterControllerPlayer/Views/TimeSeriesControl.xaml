<UserControl x:Class="CCWaterControllerPlayer.Views.TimeSeriesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="LabelText" FontSize="10" Foreground="#FF8B949E" Margin="0,0,0,4"/>
        <Canvas x:Name="ChartCanvas" Grid.Row="1" Background="Transparent"
                SizeChanged="ChartCanvas_SizeChanged"/>
    </Grid>
</UserControl>
