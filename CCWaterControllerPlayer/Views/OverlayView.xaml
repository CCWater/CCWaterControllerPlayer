<UserControl x:Class="CCWaterControllerPlayer.Views.OverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:CCWaterControllerPlayer.Services">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlay}" 
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="STATUS" FontSize="11" FontWeight="Bold" 
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlay}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverlayVisible}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverlayVisible}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pin" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Unpinned"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOverlayPinned}" Value="True">
                                            <Setter Property="Text" Value="📌 Pinned (Click-through)"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyle}" Padding="16,8"
                                Command="{Binding ToggleOverlayCommand}">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsEnableOverlay}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverlayVisible}" Value="True">
                                                    <Setter Property="Text" Value="Hide Overlay"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                        <Button Content="📌 Pin"
                                Margin="8,0,0,0" Padding="16,8"
                                Command="{Binding PinOverlayCommand}"
                                IsEnabled="{Binding IsOverlayVisible}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOverlayPinned}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="📌 Unpin" Style="{StaticResource NavButtonStyle}" 
                                Margin="8,0,0,0" Padding="16,8"
                                Command="{Binding UnpinOverlayCommand}">
                            <Button.Visibility>
                                <Binding Path="IsOverlayPinned">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Button.Visibility>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlay}" 
                               FontSize="11" FontWeight="Bold" 
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlayWidth}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource DarkTextBoxStyle}" 
                                 Text="{Binding OverlayWidth, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlayHeight}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource DarkTextBoxStyle}" 
                                 Text="{Binding OverlayHeight, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlayOpacity}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" 
                                Value="{Binding OverlayOpacity}" VerticalAlignment="Center"/>
                    </Grid>

                    <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsShowRealtime}" 
                              IsChecked="{Binding OverlayShowRealtime}"
                              Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsShowHistory}" 
                              IsChecked="{Binding OverlayShowHistory}"
                              Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsShowRecoil}" 
                              IsChecked="{Binding OverlayShowRecoilAnalysis}"
                              Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnSave}" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            HorizontalAlignment="Left" Padding="16,8"
                            Command="{Binding SaveOverlaySettingsCommand}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.ImageOverlayTitle}" 
                               FontSize="11" FontWeight="Bold" 
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImageOverlayVisible}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImageOverlayVisible}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryButtonStyle}" Padding="16,8"
                                Command="{Binding ToggleImageOverlayCommand}">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Show"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImageOverlayVisible}" Value="True">
                                                    <Setter Property="Text" Value="Hide"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                        <Button Content="📌 Pin" Margin="8,0,0,0" Padding="16,8"
                                Command="{Binding PinImageOverlayCommand}"
                                IsEnabled="{Binding IsImageOverlayVisible}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsImageOverlayPinned}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="📌 Unpin" Style="{StaticResource NavButtonStyle}" 
                                Margin="8,0,0,0" Padding="16,8"
                                Command="{Binding UnpinImageOverlayCommand}">
                            <Button.Visibility>
                                <Binding Path="IsImageOverlayPinned">
                                    <Binding.Converter>
                                        <BooleanToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Button.Visibility>
                        </Button>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.SettingsOverlayOpacity}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0" 
                                Value="{Binding ImageOverlayOpacity}" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.ImageOverlayImage}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ImageOverlayPath}" 
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="..." Style="{StaticResource NavButtonStyle}" 
                                Padding="12,6" Command="{Binding BrowseImageCommand}"/>
                    </Grid>

                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnSave}" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            HorizontalAlignment="Left" Padding="16,8"
                            Command="{Binding SaveOverlaySettingsCommand}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
