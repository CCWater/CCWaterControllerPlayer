<UserControl x:Class="CCWaterControllerPlayer.Views.RecordsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CCWaterControllerPlayer.Views"
             xmlns:vm="clr-namespace:CCWaterControllerPlayer.ViewModels"
             xmlns:models="clr-namespace:CCWaterControllerPlayer.Models"
             xmlns:services="clr-namespace:CCWaterControllerPlayer.Services">
   <Grid>
   <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RecordsTitle}" 
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnDeleteTemp}" 
                        Style="{StaticResource NavButtonStyle}" Foreground="#FFFF6B6B"
                        Command="{Binding DeleteByStatusCommand}" 
                        CommandParameter="{x:Static models:RecordStatus.Temporary}" Margin="0,0,8,0"/>
                <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnCompare}" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding ToggleCompareModeCommand}" Margin="0,0,8,0"/>
                <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnClear}" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding ClearSelectionCommand}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Height="16"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <ListBox ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord}"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimaryBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="4"
                                        Background="{StaticResource BackgroundLightBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MM/dd HH:mm}'}" 
                                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text=" | " Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextMutedBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} {1}">
                                                            <Binding Path="SampleCount"/>
                                                            <Binding Source="{x:Static services:LocalizationService.Instance}" Path="Strings.RecordsPoints"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button FontSize="11" Background="Transparent"
                                                    BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                    Command="{Binding DataContext.ToggleRecordStatusCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.TipToggleStatus}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Content" Value="&#x23F3;"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RecordStatus.Permanent}">
                                                                <Setter Property="Content" Value="💾"/>
                                                                <Setter Property="Foreground" Value="#FF4ECB71"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="&#x1F4E4;" FontSize="11"
                                                    Foreground="#FF4ECB71" Background="Transparent"
                                                    BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                    Command="{Binding DataContext.SendToOverlayCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.TipSendToOverlay}"/>
                                            <Button Content="+" FontSize="14" FontWeight="Bold"
                                                    Foreground="{StaticResource SecondaryBrush}" Background="Transparent"
                                                    BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                    Command="{Binding DataContext.ToggleRecordForCompareCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.TipCompare}"/>
                                            <Button Content="&#x270F;" FontSize="12"
                                                    Foreground="{StaticResource TextSecondaryBrush}" Background="Transparent"
                                                    BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                    Command="{Binding DataContext.StartRenameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.TipRename}"/>
                                            <Button Content="&#x1F5D1;" FontSize="12"
                                                    Foreground="#FFFF6B6B" Background="Transparent"
                                                    BorderThickness="0" Padding="4,2" Cursor="Hand"
                                                    Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.TipDelete}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource BackgroundMediumBrush}" 
                        CornerRadius="6" Padding="8" Margin="0,8,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RenamingRecord}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBox Style="{StaticResource DarkTextBoxStyle}" 
                                 Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" HorizontalAlignment="Right">
                            <Button Content="&#x2713;" Style="{StaticResource PrimaryButtonStyle}" Padding="12,4"
                                    Command="{Binding ConfirmRenameCommand}" FontSize="12"/>
                            <Button Content="&#x2717;" Style="{StaticResource NavButtonStyle}" Padding="12,4" Margin="6,0,0,0"
                                    Command="{Binding CancelRenameCommand}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.LeftStick2D}" 
                                           Foreground="{StaticResource SecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <Button Grid.Column="1" Content="&#x26F6;" FontSize="13" Padding="4,0" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Command="{Binding EnterFullscreenCommand}"
                                        CommandParameter="{x:Static vm:FullscreenMode.LeftStick}"
                                        ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnFullscreen}"/>
                            </Grid>
                            <views:TrackVisualizationControl Grid.Row="1" Margin="0,6,0,0"
                                TrackPoints="{Binding LeftStickTrackPoints}"
                                HistoryTracks="{Binding LeftStickHistoryTracks}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RightStick2D}" 
                                           Foreground="{StaticResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="&#x26F6;" FontSize="13" Padding="4,0" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Command="{Binding EnterFullscreenCommand}"
                                            CommandParameter="{x:Static vm:FullscreenMode.RightStick}"
                                            ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnFullscreen}"/>
                                    <Button Content="⛶⛶" FontSize="11" Padding="4,0" Cursor="Hand" Margin="4,0,0,0"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource TextMutedBrush}"
                                            Command="{Binding EnterFullscreenCommand}"
                                            CommandParameter="{x:Static vm:FullscreenMode.BothSticks}"
                                            ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnFullscreenBoth}"/>
                                </StackPanel>
                            </Grid>
                            <views:TrackVisualizationControl Grid.Row="1" Margin="0,6,0,0"
                                TrackPoints="{Binding RightStickTrackPoints}"
                                HistoryTracks="{Binding RightStickHistoryTracks}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.AnalysisTitle}" 
                                           Foreground="#FFFFA726" FontSize="11" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.AnalysisInputLabel}" 
                                            FontSize="9" Padding="4,2" Cursor="Hand"
                                            BorderThickness="0"
                                            Command="{Binding ToggleInputTrackCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowInputTrack}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF6C63FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.AnalysisRecoilLabel}" 
                                            FontSize="9" Padding="4,2" Cursor="Hand" Margin="2,0,0,0"
                                            BorderThickness="0"
                                            Command="{Binding ToggleRecoilTrackCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowRecoilTrack}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFFFA726"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <views:RecoilAnalysisControl Grid.Row="1" Margin="0,6,0,0"
                                InputTrack="{Binding AnalysisInputTrack}"
                                RecoilTrack="{Binding AnalysisRecoilTrack}"
                                CurrentIndex="{Binding AnalysisCurrentIndex}"
                                TriggerStartMs="{Binding TriggerStartMs}"
                                TriggerEndMs="{Binding TriggerEndMs}"
                                ShowInputTrack="{Binding ShowInputTrack}"
                                ShowRecoilTrack="{Binding ShowRecoilTrack}"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.LeftStickTimeSeries}" 
                                       Foreground="{StaticResource SecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:TimeSeriesControl Grid.Row="1" Margin="0,0,0,4"
                                DataPoints="{Binding LeftTimeSeriesX}" LineColor="#FF00D9FF" Label="L-X"/>
                            <views:TimeSeriesControl Grid.Row="2"
                                DataPoints="{Binding LeftTimeSeriesY}" LineColor="#FF4ECB71" Label="L-Y"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RightStickTimeSeries}" 
                                       Foreground="{StaticResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:TimeSeriesControl Grid.Row="1" Margin="0,0,0,4"
                                DataPoints="{Binding RightTimeSeriesX}" LineColor="#FF6C63FF" Label="R-X"/>
                            <views:TimeSeriesControl Grid.Row="2"
                                DataPoints="{Binding RightTimeSeriesY}" LineColor="#FFFF6B6B" Label="R-Y"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="12,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnStop}" 
                                        Style="{StaticResource NavButtonStyle}" 
                                        Command="{Binding StopPlaybackCommand}" Padding="8,6"/>
                                <Button Style="{StaticResource PrimaryButtonStyle}" Margin="8,0"
                                        Command="{Binding PlayPauseCommand}" Padding="12,6">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnPlay}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                            <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnPause}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider Width="80" Minimum="0.25" Maximum="4" Value="{Binding PlaybackSpeed}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PlaybackSpeed, StringFormat='{}{0:F1}x'}" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                            </StackPanel>

                            <Button Grid.Column="3" Content="&#x26F6;" FontSize="14" Padding="6,4" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0" Margin="8,0,0,0"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Command="{Binding EnterFullscreenCommand}"
                                    CommandParameter="{x:Static vm:FullscreenMode.Playback}"
                                    ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnFullscreenPlayback}"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Main" FontSize="10" Foreground="{StaticResource PrimaryBrush}" 
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                                    Value="{Binding PlaybackProgress}" Height="18"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding PlaybackProgress, StringFormat='{}{0:F0}%'}" 
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Compare" FontSize="10" Foreground="#FFFFA726" 
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                                    Value="{Binding CompareProgress}" Height="18"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding CompareProgress, StringFormat='{}{0:F0}%'}" 
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

    <Grid x:Name="FullscreenOverlay" Background="{StaticResource BackgroundDarkBrush}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FullscreenTitle" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value=""/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.LeftStick}">
                                <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.LeftStick2D}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.RightStick}">
                                <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RightStick2D}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.BothSticks}">
                                <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnFullscreenBoth}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.Playback}">
                                <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnFullscreenPlayback}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <Button Grid.Column="2" Content="&#x2716;" FontSize="16" Padding="8,4" Cursor="Hand"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Command="{Binding ExitFullscreenCommand}"/>
        </Grid>

        <!-- LeftStick fullscreen -->
        <Grid Grid.Row="1" Margin="24,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.LeftStick}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Style="{StaticResource CardStyle}">
                <views:TrackVisualizationControl
                    TrackPoints="{Binding LeftStickTrackPoints}"
                    HistoryTracks="{Binding LeftStickHistoryTracks}"/>
            </Border>
        </Grid>

        <!-- RightStick fullscreen -->
        <Grid Grid.Row="1" Margin="24,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.RightStick}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Style="{StaticResource CardStyle}">
                <views:TrackVisualizationControl
                    TrackPoints="{Binding RightStickTrackPoints}"
                    HistoryTracks="{Binding RightStickHistoryTracks}"/>
            </Border>
        </Grid>

        <!-- BothSticks fullscreen -->
        <Grid Grid.Row="1" Margin="24,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.BothSticks}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.LeftStick2D}" 
                                   Foreground="{StaticResource SecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <views:TrackVisualizationControl Grid.Row="1"
                            TrackPoints="{Binding LeftStickTrackPoints}"
                            HistoryTracks="{Binding LeftStickHistoryTracks}"/>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RightStick2D}" 
                                   Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <views:TrackVisualizationControl Grid.Row="1"
                            TrackPoints="{Binding RightStickTrackPoints}"
                            HistoryTracks="{Binding RightStickHistoryTracks}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Playback fullscreen (all 4 panels + time series) -->
        <Grid Grid.Row="1" Margin="24,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentFullscreenMode}" Value="{x:Static vm:FullscreenMode.Playback}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.LeftStick2D}" 
                                       Foreground="{StaticResource SecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:TrackVisualizationControl Grid.Row="1"
                                TrackPoints="{Binding LeftStickTrackPoints}"
                                HistoryTracks="{Binding LeftStickHistoryTracks}"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RightStick2D}" 
                                       Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:TrackVisualizationControl Grid.Row="1"
                                TrackPoints="{Binding RightStickTrackPoints}"
                                HistoryTracks="{Binding RightStickHistoryTracks}"/>
                        </Grid>
                    </Border>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.LeftStickTimeSeries}" 
                                       Foreground="{StaticResource SecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:TimeSeriesControl Grid.Row="1" Margin="0,0,0,4"
                                DataPoints="{Binding LeftTimeSeriesX}" LineColor="#FF00D9FF" Label="L-X"/>
                            <views:TimeSeriesControl Grid.Row="2"
                                DataPoints="{Binding LeftTimeSeriesY}" LineColor="#FF4ECB71" Label="L-Y"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.RightStickTimeSeries}" 
                                       Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <views:TimeSeriesControl Grid.Row="1" Margin="0,0,0,4"
                                DataPoints="{Binding RightTimeSeriesX}" LineColor="#FF6C63FF" Label="R-X"/>
                            <views:TimeSeriesControl Grid.Row="2"
                                DataPoints="{Binding RightTimeSeriesY}" LineColor="#FFFF6B6B" Label="R-Y"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Fullscreen playback controls -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundMediumBrush}" 
                CornerRadius="6" Margin="24,12" Padding="16,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnStop}" 
                                Style="{StaticResource NavButtonStyle}" 
                                Command="{Binding StopPlaybackCommand}" Padding="8,6"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Margin="8,0"
                                Command="{Binding PlayPauseCommand}" Padding="12,6">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnPlay}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Strings.BtnPause}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Slider Width="100" Minimum="0.25" Maximum="4" Value="{Binding PlaybackSpeed}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PlaybackSpeed, StringFormat='{}{0:F1}x'}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center" Margin="6,0,0,0" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Main" FontSize="11" Foreground="{StaticResource PrimaryBrush}" 
                               VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                            Value="{Binding PlaybackProgress}" Height="20"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding PlaybackProgress, StringFormat='{}{0:F0}%'}" 
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" 
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Compare" FontSize="11" Foreground="#FFFFA726" 
                               VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                            Value="{Binding CompareProgress}" Height="20"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding CompareProgress, StringFormat='{}{0:F0}%'}" 
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" 
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
    </Grid>
</UserControl>
